<configuration>

    <!-- 1. Define a Console Appender to view the logs -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 2. SET SPECIFIC CATEGORY TO DEBUG -->
    <!-- Replace "com.example.myapp.service" with your target package or class -->
    <logger name="io.serverlessworkflow.api.reflection.func" level="DEBUG" />

    <!-- 3. Global root configuration (handles all other categories) -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

</configuration>